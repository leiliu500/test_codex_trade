# Paper mode is the safe default. Live orders require both flags.
TRADING_MODE=paper
ENABLE_LIVE_ORDERS=false
MARKET_DATA_ENABLED=true
STOCK_DATA_FEED=sip
OPTION_DATA_FEED=opra
HISTORY_DATABASE_ENABLED=true
MARKET_HISTORY_QUOTE_SAMPLE_MS=250
MARKET_HISTORY_RETENTION_DAYS=7
POSTGRES_PASSWORD=change-this-local-database-password
DATABASE_URL=postgresql://spy_options:change-this-local-database-password@postgres:5432/spy_options
ALPACA_API_KEY=
ALPACA_API_SECRET=
KILL_SWITCH=false
HEALTH_HOST=127.0.0.1
HEALTH_PORT=3001
