{
  "name": "spy-options-engine",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "description": "Causal SPY intraday options research, replay, selection, execution, and risk engine",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "backtest": "tsx src/cli/backtest.ts",
    "calibrate": "tsx src/cli/calibrate.ts",
    "demo": "tsx src/cli/generateDemoReplay.ts",
    "test:historical": "tsx src/cli/historicalSignalTest.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "ws": "^8.21.1"
  }
}
